# Public site URL (used for SEO / sitemap)
NEXT_PUBLIC_SITE_URL=https://mosesfolio.online

# Optional Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXX

# Neon Postgres connection string (required to store form submissions)
# Create free DB: https://neon.tech → copy connection string
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Secret password to view submissions at /admin
ADMIN_SECRET=change-me-to-a-long-random-string
